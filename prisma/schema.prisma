generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite preview schema - Enums converted to String
model User {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  password           String
  avatar             String?
  role               String         @default("admin")
  branchId           String?
  branch             Branch?        @relation(fields: [branchId], references: [id])
  allowedIps         String?
  workDayStart       String?
  workDayEnd         String?
  twoFactorSecret    String?
  twoFactorEnabled   Boolean        @default(false)
  accentColor        String         @default("blue")
  layoutTheme        String         @default("default")
  currentSessionId   String?
  notifyEmail        Boolean        @default(true)
  notifyPush         Boolean        @default(false)
  notifyDue          Boolean        @default(true)
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  callLogs           CallLog[]
  clients            Client[]
  events             Event[]
  projects           Project[]
  services           Service[]
  subscriptions      Subscription[]
  transactions       Transaction[]
  leads              Lead[]
  quotes             Quote[]
  createdTasks       Task[]         @relation("CreatedTasks")
  assignedTasks      Task[]         @relation("AssignedTasks")
  @@map("users")
}

model Client {
  id             String         @id @default(cuid())
  name           String
  email          String?
  phone          String?
  document       String?
  company        String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  notes          String?
  status         String         @default("ativo")
  registrationId Int?           @unique
  branchId       String?
  branch         Branch?        @relation(fields: [branchId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String
  callLogs       CallLog[]
  user           User           @relation(fields: [userId], references: [id])
  services       Service[]
  subscriptions  Subscription[]
  transactions   Transaction[]
  quotes         Quote[]
  contracts      Contract[]
  tasks          Task[]
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  clients   Client[]
}

model Transaction {
  id              String            @id @default(cuid())
  description     String
  amount          Decimal           
  type            String
  category        String
  status          String            @default("pendente")
  dueDate         DateTime?
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  gatewayProvider String?
  gatewayId       String?
  paymentUrl      String?
  paymentMethod   String?
  userId          String
  clientId        String?
  serviceId       String?
  service         Service?          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  client          Client?           @relation(fields: [clientId], references: [id])
  user            User              @relation(fields: [userId], references: [id])
}

model Service {
  id               String        @id @default(cuid())
  title            String
  description      String?
  amount           Decimal       
  status           String        @default("rascunho")
  category         String?
  dueDate          DateTime?
  billingFrequency String?       @default("avulso") // mensal, trimestral, semanal, avulso
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  userId           String
  clientId         String?
  client           Client?       @relation(fields: [clientId], references: [id])
  user             User          @relation(fields: [userId], references: [id])
  transactions     Transaction[]
  events           Event[]
}

model Event {
  id            String      @id @default(cuid())
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime?
  allDay        Boolean     @default(false)
  type          String      @default("reuniao")
  status        String      @default("agendado")
  location      String?
  googleEventId String?
  clientId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userId        String
  user          User        @relation(fields: [userId], references: [id])

  // Links to other models
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  color       String?       @default("#3b82f6")
  dueDate     DateTime?
  status      String        @default("em_andamento")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  columns     TaskColumn[]
  events      Event[]
  tasks       Task[]
}

model TaskColumn {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  tasks     Task[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("A Fazer") // "A Fazer" | "Em Andamento" | "Em Revisão" | "Concluído"
  priority    String    @default("media")   // "baixa" | "media" | "alta"
  order       Int       @default(0)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relacionamentos
  userId      String
  user        User      @relation("CreatedTasks", fields: [userId], references: [id])
  assigneeId  String?
  assignee    User?     @relation("AssignedTasks", fields: [assigneeId], references: [id])
  clientId    String?
  client      Client?   @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  // Retrocompatibilidade (opcional, mas mantido se necessário para colunas de projeto)
  columnId    String?
  column      TaskColumn? @relation(fields: [columnId], references: [id], onDelete: Cascade)
  
  events      Event[]
}

model SystemModule {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model WhatsAppFlow {
  id          String         @id @default(cuid())
  name        String
  description String?
  isActive    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  edges       WhatsAppEdge[]
  nodes       WhatsAppNode[]
}

model WhatsAppNode {
  id        String       @id @default(cuid())
  type      String
  data      String
  positionX Float
  positionY Float
  flowId    String
  flow      WhatsAppFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model WhatsAppEdge {
  id           String       @id @default(cuid())
  source       String
  target       String
  sourceHandle String?
  flowId       String
  flow         WhatsAppFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model WhatsAppConfig {
  id           String   @id @default("default")
  apiUrl       String?  @default("")
  globalApiKey String?  @default("")
  instanceName String?  @default("")
  token        String?  @default("")
  waVersion    String?  @default("")
  isActive     Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

model WhatsAppChannel {
  id           String                @id @default(cuid())
  name         String
  instanceName String
  apiUrl       String?
  apiKey       String?
  webhookUrl   String?
  status       String                @default("disconnected")
  isActive     Boolean               @default(true)
  updatedAt    DateTime              @updatedAt
  interactions WhatsAppInteraction[]
}

model WhatsAppInteraction {
  id            String            @id @default(cuid())
  phone         String            @unique
  customerName  String?
  lastFlowId    String?
  currentNodeId String?
  state         String?
  lastMessageAt DateTime          @default(now())
  status        String            @default("ativo")
  channelId     String
  channel       WhatsAppChannel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages      WhatsAppMessage[]
}

model WhatsAppMessage {
  id            String              @id @default(cuid())
  fromMe        Boolean             @default(false)
  body          String
  type          String              @default("chat")
  timestamp     DateTime            @default(now())
  interactionId String
  interaction   WhatsAppInteraction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
}

model SmtpConfig {
  id        String   @id @default(cuid())
  name      String
  host      String
  port      Int
  user      String
  pass      String
  fromEmail String
  fromName  String?
  secure    Boolean  @default(true)
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model CommunicationTemplate {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String
  subject   String?
  createdAt DateTime @default(now())
}

model ScheduledTask {
  id        String    @id @default(cuid())
  name      String
  type      String
  cron      String
  lastRun   DateTime?
  nextRun   DateTime?
  status    String    @default("active")
  config    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Subscription {
  id              String   @id @default(cuid())
  description     String
  amount          Decimal  
  interval        String   @default("monthly")
  status          String   @default("active")
  nextBillingDate DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model NfeConfig {
  id                 String   @id @default("default")
  cnpj               String
  inscricaoMunicipal String
  razaoSocial        String
  senhaCertificado   String?
  certificadoBase64  String?
  ambiente           String   @default("homologacao")
  updatedAt          DateTime @updatedAt
}

model SystemLicense {
  id           String    @id @default("default")
  key          String?   @unique
  status       String    @default("active")
  validUntil   DateTime?
  lastCheck    DateTime  @default(now())
  customerName String?
  updatedAt    DateTime  @updatedAt
}

model SystemBranding {
  id           String   @id @default("default")
  name         String   @default("NextWave CRM")
  logoUrl      String?
  faviconUrl   String?
  primaryColor String   @default("#3b82f6")
  supportEmail String?
  supportPhone String?
  updatedAt    DateTime @updatedAt
}

model CallLog {
  id           String   @id @default(cuid())
  direction    String
  from         String
  to           String
  duration     Int      @default(0)
  status       String   @default("completed")
  recordingUrl String?
  notes        String?
  timestamp    DateTime @default(now())
  userId       String
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
}

model PbxConfig {
  id          String   @id @default("default")
  provider    String   @default("simulator")
  apiKey      String?
  apiSecret   String?
  accountSid  String?
  sipDomain   String?
  sipUser     String?
  sipPassword String?
  isActive    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model PaymentGatewayConfig {
  id          String   @id @default(cuid())
  name        String
  provider    String   @unique
  credentials String
  isActive    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model McpConfig {
  id             String   @id @default("default")
  apiKey         String
  allowedIps     String?    @default("[]")
  allowedOrigins String?    @default("[]")
  rateLimit      Int      @default(100)
  rateWindow     Int      @default(60000)
  logLevel       String   @default("info")
  port           Int      @default(3001)
  isActive       Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}

model WaMessage {
  id           String   @id
  instanceName String   
  remoteJid    String   
  messageId    String?  
  body         String
  fromMe       Boolean  @default(false) 
  status       String   @default("PENDING")
  timestamp    Int
  createdAt    DateTime @default(now()) 

  @@index([instanceName, remoteJid, timestamp])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  source    String?
  value     Decimal?   @default(0) 
  status    String     @default("novo")
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  userId    String
  user      User       @relation(fields: [userId], references: [id])
}

model Quote {
  id          String      @id @default(cuid())
  title       String
  description String?
  value       Decimal     
  status      String      @default("rascunho")
  validUntil  DateTime?
  clientId    String?
  client      Client?     @relation(fields: [clientId], references: [id])
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  items       QuoteItem[]
  contract    Contract?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model QuoteItem {
  id          String  @id @default(cuid())
  description String
  quantity    Decimal 
  price       Decimal 
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Contract {
  id            String         @id @default(cuid())
  content       String
  status        String         @default("pendente")
  signedAt      DateTime?
  signatureIp   String?
  signatureName String?
  quoteId       String?        @unique
  quote         Quote?         @relation(fields: [quoteId], references: [id])
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
