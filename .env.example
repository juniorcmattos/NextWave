# Exemplo de configuração de ambiente para PostgreSQL (Supabase)
# Copie este arquivo para .env e preencha os valores

# Supabase Client
NEXT_PUBLIC_SUPABASE_URL="https://tmukhrowzqhsveqeerpz.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_aMjUeR_1im1_eVN19V_uQg_PmAVTb_m"

# Supabase Connection Pooling (Transaction Mode - Port 6543)
DATABASE_URL="postgresql://postgres:[password]@tmukhrowzqhsveqeerpz.supabase.co:6543/postgres?pgbouncer=true"

# Supabase Direct Connection (Session Mode - Port 5432) - Usado para Migrations
DIRECT_URL="postgresql://postgres:[password]@tmukhrowzqhsveqeerpz.supabase.co:5432/postgres"

# Outras configurações mantidas...
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="seu-secret-aqui"

