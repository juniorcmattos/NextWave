generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role         String   @default("admin")
  allowedIps   String?  // IPs permitidos (separados por vírgula ou "*" para todos)
  workDayStart String?  // Formato HH:mm (ex: 08:00)
  workDayEnd   String?  // Formato HH:mm (ex: 18:00)
  twoFactorSecret   String?
  twoFactorEnabled  Boolean  @default(false)
  accentColor  String   @default("blue")
  layoutTheme  String   @default("default")
  currentSessionId String?  // ID da última sessão ativa (Single Device Access)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients      Client[]
  transactions Transaction[]
  services     Service[]
  events       Event[]
  projects     Project[]
  subscriptions Subscription[]
  callLogs     CallLog[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  document  String?
  company   String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  notes     String?
  status    String   @default("ativo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  services     Service[]
  subscriptions Subscription[]
  callLogs      CallLog[]
}

model Transaction {
  id          String    @id @default(cuid())
  description String
  amount      Float
  type        String
  category    String
  status      String    @default("pendente")
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Gateway Fields (Scalable)
  gatewayProvider String?
  gatewayId       String?
  paymentUrl      String?
  paymentMethod   String?

  userId   String
  user     User    @relation(fields: [userId], references: [id])
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
}

model Service {
  id          String    @id @default(cuid())
  title       String
  description String?
  amount      Float
  status      String    @default("rascunho")
  category    String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId   String
  user     User    @relation(fields: [userId], references: [id])
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean   @default(false)
  type        String    @default("reuniao")
  status      String    @default("agendado")
  location    String?
  clientId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?  @default("#3b82f6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])
  columns     TaskColumn[]
}

model TaskColumn {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    String    @default("media") // baixa, media, alta
  scope       String    @default("empresa") // empresa, pessoal
  order       Int       @default(0)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  columnId    String
  column      TaskColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
}

model SystemModule {
  id          String   @id @default(cuid())
  key         String   @unique // ex: 'financeiro', 'whatsapp', 'projetos'
  name        String
  description String?
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model WhatsAppFlow {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(false)
  nodes       WhatsAppNode[]
  edges       WhatsAppEdge[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppNode {
  id          String       @id @default(cuid())
  type        String       // message, menu, input, condition
  data        String       // JSON com conteúdo do nó (texto, opções, etc)
  positionX   Float
  positionY   Float
  flowId      String
  flow        WhatsAppFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model WhatsAppEdge {
  id          String       @id @default(cuid())
  source      String
  target      String
  sourceHandle String?
  flowId      String
  flow        WhatsAppFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model WhatsAppConfig {
  id             String   @id @default("default")
  apiUrl         String?  @default("")
  globalApiKey   String?  @default("")
  instanceName   String?  @default("")
  token          String?  @default("")
  waVersion      String?  @default("")
  isActive       Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}

model WhatsAppChannel {
  id          String   @id @default(cuid())
  name        String   // Ex: 'Suporte Comercial', 'Financeiro'
  instanceName String   // Nome da instância na API (Evolution/WPP)
  apiUrl      String?
  apiKey      String?
  webhookUrl  String?
  status      String   @default("disconnected") // connected, disconnected, connecting
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  
  interactions WhatsAppInteraction[]
}

model WhatsAppInteraction {
  id          String   @id @default(cuid())
  phone       String   @unique
  customerName String?
  lastFlowId  String?
  currentNodeId String?
  state       String?  // JSON com variáveis capturadas
  lastMessageAt DateTime @default(now())
  status      String   @default("ativo") // ativo, finalizado
  
  channelId   String
  channel     WhatsAppChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages    WhatsAppMessage[]
}

model WhatsAppMessage {
  id            String   @id @default(cuid())
  fromMe        Boolean  @default(false)
  body          String
  type          String   @default("chat") // chat, image, audio, video
  timestamp     DateTime @default(now())
  
  interactionId String
  interaction   WhatsAppInteraction @relation(fields: [interactionId], references: [id], onDelete: Cascade)
}

model SmtpConfig {
  id          String   @id @default(cuid())
  name        String   // Ex: 'Suporte', 'Financeiro'
  host        String
  port        Int
  user        String
  pass        String
  fromEmail   String
  fromName    String?
  secure      Boolean  @default(true)
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model CommunicationTemplate {
  id        String   @id @default(cuid())
  name      String   // ex: 'Cobranca Atrasada'
  type      String   // 'whatsapp' ou 'email'
  content   String   // Corpo da mensagem (aceita variáveis {nome}, {valor})
  subject   String?  // Apenas para e-mail
  createdAt DateTime @default(now())
}

model ScheduledTask {
  id          String   @id @default(cuid())
  name        String   // Ex: 'Backup Diário', 'Cobrança WhatsApp'
  type        String   // 'email_blast', 'whatsapp_billing', 'backup', 'wa_check'
  cron        String   // Expressão cron ou formato simplificado '0 3 * * *'
  lastRun     DateTime?
  nextRun     DateTime?
  status      String   @default("active") // 'active', 'disabled', 'failed'
  config      String?  // JSON string com configurações extras
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Subscription {
  id              String   @id @default(cuid())
  description     String   // Ex: 'Plano Mensal Gold'
  amount          Float
  interval        String   @default("monthly") // monthly, yearly
  status          String   @default("active") // active, canceled, past_due
  nextBillingDate DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  clientId String
  client   Client @relation(fields: [clientId], references: [id])
}

model NfeConfig {
  id                String   @id @default("default")
  cnpj              String
  inscricaoMunicipal String
  razaoSocial       String
  senhaCertificado  String?  // Criptografado
  certificadoBase64 String?  // Arquivo PFX em Base64 criptografado
  ambiente          String   @default("homologacao") // homologacao, producao
  updatedAt         DateTime @updatedAt
}
model SystemLicense {
  id          String   @id @default("default")
  key         String?  @unique
  status      String   @default("active") // active, suspended, expired, trial
  validUntil  DateTime?
  lastCheck   DateTime @default(now())
  customerName String?
  updatedAt   DateTime @updatedAt
}

model SystemBranding {
  id          String   @id @default("default")
  name        String   @default("NextWave CRM")
  logoUrl     String?
  faviconUrl  String?
  primaryColor String  @default("#3b82f6")
  supportEmail String?
  supportPhone String?
  updatedAt   DateTime @updatedAt
}
model CallLog {
  id            String   @id @default(cuid())
  direction     String   // incoming, outgoing
  from          String
  to            String
  duration      Int      @default(0) // seconds
  status        String   @default("completed") // completed, missed, busy, failed
  recordingUrl  String?
  notes         String?
  timestamp     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id])
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])
}

model PbxConfig {
  id            String   @id @default("default")
  provider      String   @default("simulator") // twilio, sip, simulator
  apiKey        String?
  apiSecret     String?
  accountSid    String?
  sipDomain     String?
  sipUser       String?
  sipPassword   String?
  isActive      Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model PaymentGatewayConfig {
  id          String   @id @default(cuid())
  name        String   // Ex: "InfinitePay", "Mercado Pago"
  provider    String   @unique // Ex: "infinitepay", "mercadopago"
  credentials String   // JSON string with API keys, tags, etc.
  isActive    Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

model McpConfig {
  id             String   @id @default("default")
  apiKey         String
  allowedIps     String?  @default("[]")
  allowedOrigins String?  @default("[]")
  rateLimit      Int      @default(100)
  rateWindow     Int      @default(60000)
  logLevel       String   @default("info")
  port           Int      @default(3001)
  isActive       Boolean  @default(false)
  updatedAt      DateTime @updatedAt
}
